{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es6",
    "sourceMap": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src", // phục vụ build typescrippt sang javascript ( quyết định file nào build file nào,và cấu trúc như thế nào )
    "baseUrl": ".", // định nghĩa đường dẫn của file xuất phát từ đâu  absolute path)
    "paths": {
      "config/*": ["./src/config/*"],
      "controllers/*": ["./src/controllers/*"],
      "middleware/*": ["./src/middleware/*"],
      "models/*": ["./src/models/*"],
      "routes/*": ["./src/routes/*"],
      "services/*": ["./src/services/*"],
      "validation/*": ["./src/validation/*"],
      "types/*": ["./src/types/*"]
      
    }
  },
  "include": ["src/**/*"]
}
